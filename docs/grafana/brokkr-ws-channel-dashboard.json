  "panels": [
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "Agents currently holding an open internal WS connection to this broker process.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "text": {},
        "textMode": "auto"
      },
      "pluginVersion": "8.0.0",
      "targets": [{ "expr": "brokkr_ws_connected_agents", "refId": "A" }],
      "title": "Connected Agents",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "Subscribers on the live fan-out hub (WS-11), aggregated across all stacks.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "text": {},
        "textMode": "auto"
      },
      "pluginVersion": "8.0.0",
      "targets": [{ "expr": "brokkr_ws_live_subscribers", "refId": "A" }],
      "title": "Live Subscribers",
      "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "Retention-worker eviction passes per second. MUST stay above zero while the broker is up — a flat line at 0 means the 6h retention ceiling is being silently violated. See the brokkr-ws-channel alert rule.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          },
          "mappings": [],
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "pluginVersion": "8.0.0",
      "targets": [
        {
          "expr": "rate(brokkr_ws_log_eviction_runs_total[5m])",
          "legendFormat": "eviction passes/s",
          "refId": "A"
        }
      ],
      "title": "Eviction Worker Liveness (rate)",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "WS frame throughput by direction (in = agent→broker uplink, out = broker→agent) and wire-enum type.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 25,
            "gradientMode": "none",
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "mappings": [],
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "pluginVersion": "8.0.0",
      "targets": [
        {
          "expr": "rate(brokkr_ws_messages_total[5m])",
          "legendFormat": "{{direction}} · {{type}}",
          "refId": "A"
        }
      ],
      "title": "WS Message Rate by direction · type",
      "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "Rows evicted per second by the 6h retention worker, by telemetry table. Non-zero is normal under sustained telemetry; it should track ingest minus what ages out within 6h.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 25,
            "gradientMode": "none",
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "mappings": [],
          "unit": "rps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "pluginVersion": "8.0.0",
      "targets": [
        {
          "expr": "rate(brokkr_ws_telemetry_evicted_total[5m])",
          "legendFormat": "{{table}}",
          "refId": "A"
        }
      ],
      "title": "Telemetry Rows Evicted by table (rate)",
      "type": "timeseries"
    }
  ],
