# Stage 1: Build the application
FROM rust:1.90-slim-bookworm AS builder
WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y \
    libssl-dev \
    pkg-config \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy source code and build
COPY . .
RUN cargo build --bin brokkr-agent --release

# Stage 2: Create the final image
FROM debian:bookworm-slim

# Declare build arguments for multi-arch support
ARG TARGETOS=linux
ARG TARGETARCH=amd64

# Install runtime dependencies and kubectl
RUN apt-get update && apt-get install -y \
    libpq-dev \
    curl \
    ca-certificates \
    && curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/${TARGETOS}/${TARGETARCH}/kubectl" \
    && chmod +x kubectl \
    && mv kubectl /usr/local/bin/ \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN groupadd -g 10001 brokkr && \
    useradd -r -u 10001 -g brokkr brokkr

WORKDIR /usr/local/bin
COPY --from=builder /app/target/release/brokkr-agent .
RUN chmod +x brokkr-agent && \
    chown brokkr:brokkr brokkr-agent && \
    chown brokkr:brokkr kubectl

USER brokkr
EXPOSE 8080
ENTRYPOINT ["./brokkr-agent"]
